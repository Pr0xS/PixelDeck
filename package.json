{
  "name": "pixeldeck",
  "version": "0.3.3",
  "private": true,
  "description": "Visual editor for designing polished App Store & Play Store screenshots. Drag-and-drop device mockups, text, shapes, and gradients, then export PNGs from the browser or batch-export via CLI.",
  "keywords": [
    "app-store",
    "screenshots",
    "mockup",
    "canvas",
    "konva",
    "react",
    "vite",
    "cli",
    "playwright",
    "localization"
  ],
  "license": "MIT",
  "author": "PixelDeck contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pr0xS/PixelDeck.git"
  },
  "homepage": "https://github.com/Pr0xS/PixelDeck#readme",
  "bugs": {
    "url": "https://github.com/Pr0xS/PixelDeck/issues"
  },
  "type": "module",
  "bin": {
    "pixeldeck": "./cli/index.mjs"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "cli": "node cli/index.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@playwright/test": "^1.61.0",
    "js-yaml": "^4.2.0",
    "jszip": "^3.10.1",
    "konva": "^10.3.0",
    "nanoid": "^5.1.11",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-konva": "^19.2.4",
    "use-image": "^1.1.4",
    "zundo": "^2.3.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.13.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  }
}
