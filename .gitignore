# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ─── Build output ─────────────────────────────────────────────────────────────
dist/
dist-ssr/
*.tsbuildinfo

# ─── Environment variables ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.local

# ─── AI agent tooling (never commit) ──────────────────────────────────────────
.engram/
.opencode/
.cursorrules
.aider*
.slim/deepwork/

# ─── User-generated runtime dirs ──────────────────────────────────────────────
# Local workspace data — not part of the source. The CLI creates these on demand.
# To share a sample project or template, put it under public/templates/ instead.
/projects/
/screenshots/
/output/
/templates/

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
